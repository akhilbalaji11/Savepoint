# Savepoint - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ---- Supabase Edge Function env vars ----
# Set these in: Supabase Dashboard -> Edge Functions -> Manage Secrets
# (Do NOT put these in this file - they stay server-side only)

# IGDB_CLIENT_ID=YOUR_IGDB_CLIENT_ID
# IGDB_CLIENT_SECRET=YOUR_IGDB_CLIENT_SECRET

# Optional AI features (Edge Function env only)
# OPENAI_API_KEY=sk-...  <- Leave blank to use deterministic tag fallback
